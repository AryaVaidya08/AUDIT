CHUNK_SIZE_LINES=120
MAX_FILES=5000
MAX_FILE_SIZE_BYTES=1000000

INCLUDE_EXTENSIONS=.py,.js,.jsx,.ts,.tsx,.java,.go,.rb,.php,.cs,.cpp,.c,.h,.rs,.swift,.kt,.scala,.sql,.sh,.yaml,.yml,.json,.toml,.ini,.cfg,.env,.md
INCLUDE_FILENAMES=Dockerfile,docker-compose.yml,docker-compose.yaml,Makefile

EXCLUDE_DIRS=.git,.venv,venv,node_modules,dist,build,__pycache__,.mypy_cache,.pytest_cache,.cache,.chroma
EXCLUDE_GLOBS=*.min.js,*.lock,*.png,*.jpg,*.jpeg,*.gif,*.svg,*.pdf,*.zip,*.tar,*.gz,*.exe,*.bin

OPENAI_API_KEY=sk-proj...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64

KB_DIR=backend/app/scan/kb
CHROMA_COLLECTION_CODE_CHUNKS=code_chunks
CHROMA_COLLECTION_SECURITY_KB=security_kb
RETRIEVAL_TOP_K=5
DEBUG_RETRIEVAL=false

SCAN_MODEL=gpt-4.1-mini
SCAN_TOP_K=5
SCAN_SIMILARITY_THRESHOLD=0.2
SCAN_MAX_CHUNKS=300
SCAN_REPAIR_RETRIES=1

SCAN_PREFILTER_ENABLED=true
SCAN_PREFILTER_MIN_SCORE=0.2
SCAN_PREFILTER_MAX_CANDIDATES=200

SCAN_CACHE_ENABLED=true
SCAN_MAX_INFLIGHT_LLM_CALLS=4

SCAN_CHECKPOINT_EVERY=5

SCAN_LLM_TIMEOUT_SECONDS=20
